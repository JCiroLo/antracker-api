{
  "name": "antracker-backend",
  "version": "1.0.1",
  "description": "Antracker API built with Express and Supabase",
  "main": "dist/index.js",
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
